# Copy this file to .env and fill in your values

# Your Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Name of the WhatsApp group chat to watch (case-insensitive, partial match OK)
WATCH_GROUP_NAME=My Group

# The recipient's WhatsApp number (where answers are delivered).
# Digits only, with country code, no + or spaces. Example for a Nigerian number:
OWNER_NUMBER=2348012345678
